services/*/server
services/*/adapter
services/*/agent
services/*/mcp-echo

# Go test binaries and coverage artifacts
*.test
*.out
coverage.*
*.coverprofile
profile.cov

# Go dependency directories
# vendor/

# Go workspace files are local unless the team explicitly adopts a shared workspace.
go.work
go.work.sum

