# Compatibility notice.
#
# Repository configuration is now profile-first:
#   config/base.yaml
#   config/dev.yaml
#   config/staging.yaml
#   config/production.yaml
#
# Local secrets use the repository-root template:
#   cp .env.example .env.local
#
# Local scripts render Docker Compose and host-run environments through:
#   scripts/config/load-profile.sh
#
# Do not copy this file to deploy/.env. deploy/.env is no longer the default
# configuration source.
