# Local/demo integration baseline. Values are placeholders, not production secrets.
# Normal setup:
#   cp deploy/.env.example deploy/.env

COMPOSE_PROJECT_NAME=software-teamwork-local

# Infrastructure ports exposed by deploy/docker-compose.yml.
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

GATEWAY_HTTP_PORT=8080
AUTH_HTTP_PORT=8001
FILE_HTTP_PORT=8082
KNOWLEDGE_HTTP_PORT=8083
QA_HTTP_PORT=8084
DOCUMENT_HTTP_PORT=8085
AI_GATEWAY_HTTP_PORT=8086

POSTGRES_PASSWORD=local-demo-postgres-password
MINIO_ROOT_USER=minio_local_demo
MINIO_ROOT_PASSWORD=minio-local-demo-password

# Shared local placeholders used by host-run services.
INTERNAL_SERVICE_TOKEN=local-dev-internal-service-token-change-me
AUTH_GATEWAY_ADMIN_SERVICE_TOKEN=local-dev-gateway-admin-token-change-me
GATEWAY_AUTH_ADMIN_SERVICE_TOKEN=local-dev-gateway-admin-token-change-me
TOKEN_HASH_SECRET=local-demo-token-hash-secret-change-me
AI_GATEWAY_SERVICE_TOKEN_HASHES=sha256:26c6719c056dabe8530ea09f1e8f7593cbcf98a060731c0fc786a5eb48e71ce7
AI_GATEWAY_CREDENTIAL_ENCRYPTION_KEY=local-demo-credential-key-change-me
AI_GATEWAY_CREDENTIAL_ENCRYPTION_KEY_REF=local-demo-key-v1

LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=LocalDemoAdmin#12345
LOCAL_SUPER_ADMIN_USERNAME=superadmin
LOCAL_SUPER_ADMIN_PASSWORD=LocalDemoAdmin#12345

# PostgreSQL URLs used by host-run migrations and services.
POSTGRES_ADMIN_URL=postgres://postgres:local-demo-postgres-password@localhost:5432/postgres?sslmode=disable
AUTH_DATABASE_URL=postgres://auth_app:auth_app_dev@localhost:5432/auth_system?sslmode=disable
FILE_DATABASE_URL=postgres://file_app:file_app_dev@localhost:5432/file_system?sslmode=disable
KNOWLEDGE_DATABASE_URL=postgres://knowledge_app:knowledge_app_dev@localhost:5432/knowledge_system?sslmode=disable
QA_DATABASE_URL=postgres://qa_app:qa_app_dev@localhost:5432/qa_system?sslmode=disable
DOCUMENT_DATABASE_URL=postgres://document_app:document_app_dev@localhost:5432/document_system?sslmode=disable
AI_GATEWAY_DATABASE_URL=postgres://ai_gateway_app:ai_gateway_app_dev@localhost:5432/ai_gateway_system?sslmode=disable
DB_TYPE=postgres

# Host-run uv/Python package index for mainland China developer networks.
UV_DEFAULT_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple

# Host-run service bind addresses.
AUTH_HTTP_ADDR=:8001
FILE_HTTP_ADDR=:8082
KNOWLEDGE_HTTP_ADDR=:8083
QA_HTTP_ADDR=:8084
DOCUMENT_HTTP_ADDR=:8085
AI_GATEWAY_HTTP_ADDR=:8086
GATEWAY_HTTP_ADDR=:8080

# Host-run service dependencies.
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
GATEWAY_REDIS_ADDR=localhost:6379
GATEWAY_AUTH_BASE_URL=http://localhost:8001
GATEWAY_KNOWLEDGE_BASE_URL=http://localhost:8083
GATEWAY_QA_BASE_URL=http://localhost:8084
GATEWAY_DOCUMENT_BASE_URL=http://localhost:8085
GATEWAY_AI_GATEWAY_BASE_URL=http://localhost:8086

FILE_STORAGE_BACKEND=minio
FILE_MINIO_ENDPOINT=localhost:9000
FILE_MINIO_ACCESS_KEY=minio_local_demo
FILE_MINIO_SECRET_KEY=minio-local-demo-password
FILE_MINIO_BUCKET=software-teamwork-local
FILE_MINIO_USE_SSL=false
FILE_MINIO_REGION=
FILE_MINIO_TIMEOUT=10s

KNOWLEDGE_REDIS_ADDR=localhost:6379
KNOWLEDGE_SERVICE_TOKEN=local-dev-internal-service-token-change-me
FILE_SERVICE_BASE_URL=http://localhost:8082
# Optional Knowledge MCP Streamable HTTP endpoint. Disabled unless
# KNOWLEDGE_MCP_ADDR is set. MCP HTTP ignores caller-supplied user/permission
# headers and uses this fixed service account context for adapter calls.
# KNOWLEDGE_MCP_ADDR=127.0.0.1:8093
KNOWLEDGE_MCP_USER_ID=knowledge_mcp_service
KNOWLEDGE_MCP_PERMISSIONS=knowledge:read
# KNOWLEDGE_MCP_ROLES=

AI_GATEWAY_BASE_URL=http://localhost:8086
AI_GATEWAY_SERVICE_TOKEN=local-dev-internal-service-token-change-me
AI_GATEWAY_URL=http://localhost:8086/internal/v1/chat/completions
AI_GATEWAY_TOKEN=local-dev-internal-service-token-change-me
AI_GATEWAY_TOKEN_HEADER=X-Service-Token
AI_GATEWAY_PROFILE_ID=default-chat
MODEL_ID=local-placeholder-chat
QA_SETTINGS_OPEN=false
QA_ADMIN_USER_IDS=

# QA discovers the host-run Document MCP server with this alias. The database
# seed stores only non-secret metadata; the local token remains environment-owned.
MCP_TRANSPORT=streamable_http
MCP_SERVER_ALIAS=document
MCP_SERVER_URL=http://localhost:8085/mcp
MCP_SERVER_TOKEN=local-dev-internal-service-token-change-me
MCP_SERVER_TOKEN_HEADER=Authorization

DOCUMENT_REDIS_ADDR=localhost:6379
DOCUMENT_FILE_SERVICE_URL=http://localhost:8082
DOCUMENT_FILE_SERVICE_TOKEN=local-dev-internal-service-token-change-me
DOCUMENT_AI_GATEWAY_URL=http://localhost:8086
DOCUMENT_AI_GATEWAY_PROFILE_ID=default-chat
DOCUMENT_AI_GATEWAY_SERVICE_TOKEN=local-dev-internal-service-token-change-me
DOCUMENT_KNOWLEDGE_SERVICE_URL=http://localhost:8083
DOCUMENT_KNOWLEDGE_SERVICE_TOKEN=local-dev-internal-service-token-change-me

# Docker image source overrides for infrastructure pulls. The team default is
# DaoCloud's public mirror path for mainland China developer networks. To use
# Docker Hub directly, remove these *_IMAGE lines from deploy/.env; Compose then
# falls back to the pinned Docker Hub defaults in deploy/docker-compose.yml.
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine
REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine
QDRANT_IMAGE=docker.m.daocloud.io/qdrant/qdrant:v1.18.2
MINIO_IMAGE=docker.m.daocloud.io/minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=docker.m.daocloud.io/minio/mc:RELEASE.2025-08-13T08-35-41Z

# Knowledge vendor adapter. Host-run Knowledge talks to the runtime through the published runtime API port.
VENDOR_RUNTIME_URL=http://127.0.0.1:9380
VENDOR_RUNTIME_SERVICE_TOKEN=local-dev-runtime-service-token-change-me
KNOWLEDGE_RUNTIME_SERVICE_TOKEN=local-dev-runtime-service-token-change-me
# Real RAGFlow ingestion is opt-in. Keep auto-ingestion disabled until a
# reachable doc engine and embedding provider are configured for the host-run
# Python runtime.
KNOWLEDGE_AUTO_START_INGESTION=false
# DOC_ENGINE=elasticsearch

# Optional provider credential for the Python knowledge-runtime default
# embedding/rerank model. Set this in a local env file or shell; never commit
# a real key.
# KNOWLEDGE_RUNTIME_MODEL_API_KEY=
# KNOWLEDGE_RUNTIME_EMBEDDING_FACTORY=SILICONFLOW
# KNOWLEDGE_RUNTIME_EMBEDDING_MODEL=BAAI/bge-m3
# KNOWLEDGE_RUNTIME_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# KNOWLEDGE_RUNTIME_RERANK_FACTORY=SILICONFLOW
# KNOWLEDGE_RUNTIME_RERANK_MODEL=BAAI/bge-reranker-v2-m3
# KNOWLEDGE_RUNTIME_RERANK_BASE_URL=https://api.siliconflow.cn/v1
# Optional rerank model id forwarded to vendor when knowledge-queries rerank=true
# KNOWLEDGE_VENDOR_RERANK_ID=BAAI/bge-reranker-v2-m3@default@SILICONFLOW
