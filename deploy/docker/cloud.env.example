# Cloud-backed Docker app stack template.
# Copy to the ignored root file before starting:
#   cp deploy/docker/cloud.env.example .env.docker.cloud
#
# This path builds/runs product services in Docker and uses cloud/external
# PostgreSQL, Redis, object storage, Knowledge runtime, PaddleOCR, and model APIs.
# It does not start local Elasticsearch, MinIO, PostgreSQL, Redis, OCR, or
# Knowledge runtime worker containers.

COMPOSE_PROJECT_NAME=software-teamwork-cloud
DOCKER_FRONTEND_PORT=18080
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:18080

# Optional image source overrides. Leave empty for official upstream images.
DOCKER_IMAGE_REGISTRY_PREFIX=
GO_DOCKER_GOPROXY=https://proxy.golang.org,direct
GO_DOCKER_GOSUMDB=sum.golang.org
GO_DOCKER_IMAGE=golang:1.25-alpine
ALPINE_DOCKER_IMAGE=alpine:3.22
ALPINE_MIRROR=
BUN_DOCKER_IMAGE=oven/bun:1.3.12-alpine
NGINX_DOCKER_IMAGE=nginx:1.27-alpine

# Required cloud secrets. Replace every placeholder before starting; the startup
# script rejects local-dev/local-demo/change-me values in this cloud template.
# If INTERNAL_SERVICE_TOKEN changes, recompute AI_GATEWAY_SERVICE_TOKEN_HASHES.
INTERNAL_SERVICE_TOKEN=<cloud-internal-service-token>
AUTH_GATEWAY_ADMIN_SERVICE_TOKEN=<cloud-auth-admin-service-token>
GATEWAY_AUTH_ADMIN_SERVICE_TOKEN=<cloud-auth-admin-service-token>
TOKEN_HASH_SECRET=<cloud-token-hash-secret>
AI_GATEWAY_SERVICE_TOKEN_HASHES=<sha256-of-internal-service-token>
AI_GATEWAY_CREDENTIAL_ENCRYPTION_KEY=<cloud-ai-gateway-credential-encryption-key>
AI_GATEWAY_CREDENTIAL_ENCRYPTION_KEY_REF=<cloud-ai-gateway-key-ref>

# Cloud PostgreSQL. POSTGRES_ADMIN_URL is required only when
# DOCKER_SEED_ENABLED=true. It must connect to the same host and be allowed to
# \connect auth_system, file_system, knowledge_system, qa_system,
# document_system, and ai_gateway_system for seed data. When cloud databases are
# already migrated/seeded, keep DOCKER_SEED_ENABLED=false and leave this as a
# placeholder.
POSTGRES_ADMIN_URL=postgres://postgres:<cloud-admin-password>@<cloud-postgres-host>:5432/postgres?sslmode=require
AUTH_DATABASE_URL=postgres://auth_app:<auth-password>@<cloud-postgres-host>:5432/auth_system?sslmode=require
FILE_DATABASE_URL=postgres://file_app:<file-password>@<cloud-postgres-host>:5432/file_system?sslmode=require
KNOWLEDGE_DATABASE_URL=postgres://knowledge_app:<knowledge-password>@<cloud-postgres-host>:5432/knowledge_system?sslmode=require
QA_DATABASE_URL=postgres://qa_app:<qa-password>@<cloud-postgres-host>:5432/qa_system?sslmode=require
DOCUMENT_DATABASE_URL=postgres://document_app:<document-password>@<cloud-postgres-host>:5432/document_system?sslmode=require
AI_GATEWAY_DATABASE_URL=postgres://ai_gateway_app:<ai-gateway-password>@<cloud-postgres-host>:5432/ai_gateway_system?sslmode=require

# Optional migration URLs when app users do not have DDL privileges.
# AUTH_MIGRATION_DATABASE_URL=
# FILE_MIGRATION_DATABASE_URL=
# KNOWLEDGE_MIGRATION_DATABASE_URL=
# QA_MIGRATION_DATABASE_URL=
# DOCUMENT_MIGRATION_DATABASE_URL=
# AI_GATEWAY_MIGRATION_DATABASE_URL=

# Cloud Redis.
GATEWAY_REDIS_ADDR=<cloud-redis-host>:6379
GATEWAY_REDIS_USERNAME=
GATEWAY_REDIS_PASSWORD=
GATEWAY_REDIS_DB=0
GATEWAY_REDIS_TLS_ENABLED=false
DOCUMENT_REDIS_ADDR=<cloud-redis-host>:6379
DOCUMENT_REDIS_USERNAME=
DOCUMENT_REDIS_PASSWORD=
DOCUMENT_REDIS_DB=0
DOCUMENT_REDIS_TLS_ENABLED=false

# Cloud object storage using the File service MinIO/S3-compatible client.
FILE_MINIO_ENDPOINT=<cloud-object-storage-host>:9000
FILE_MINIO_ACCESS_KEY=<cloud-object-storage-access-key>
FILE_MINIO_SECRET_KEY=<cloud-object-storage-secret-key>
FILE_MINIO_BUCKET=software-teamwork-cloud
FILE_MINIO_USE_SSL=true
FILE_MINIO_REGION=

# Cloud Knowledge runtime. This should be a deployed runtime API, not a local
# services/knowledge-runtime process.
VENDOR_RUNTIME_URL=https://<cloud-knowledge-runtime-host>
VENDOR_RUNTIME_SERVICE_TOKEN=<cloud-runtime-token>
KNOWLEDGE_RUNTIME_READINESS_MODE=query
KNOWLEDGE_AUTO_START_INGESTION=true

# Cloud OCR parser seed. Required only when DOCKER_SEED_ENABLED=true so uploaded
# PDFs use the PaddleOCR cloud parser config instead of any local OCR path.
PADDLEOCR_BASE_URL=https://paddleocr.aistudio-app.com
PADDLEOCR_ACCESS_TOKEN=<cloud-paddleocr-token>
PADDLEOCR_ALGORITHM=PP-StructureV3

# Cloud seed is disabled by default so copying this template cannot write local
# demo users/config into a cloud database. Set DOCKER_SEED_ENABLED=true only for
# an ephemeral cloud DB where applying deploy/seeds/001-local-demo-seed.sql and
# companion demo/profile seeds is intentional.
DOCKER_SEED_ENABLED=false

# Cloud model provider seed. Fill these only when DOCKER_SEED_ENABLED=true and
# AI_GATEWAY_LOCAL_SEED_ENABLED is not false. The seed step creates/updates
# default-chat and syncs QA/Document to that profile. If the cloud database
# already has model profiles, parser config, users, and QA settings, keep
# DOCKER_SEED_ENABLED=false and provide MODEL_ID / DOCUMENT_AI_GATEWAY_MODEL only
# when requests should explicitly override the model stored on the AI Gateway
# profile. Seed-only AI_GATEWAY_LOCAL_CHAT_MODEL is not used as a runtime
# Document/QA model fallback in the cloud stack.
AI_GATEWAY_LOCAL_SEED_ENABLED=true
AI_GATEWAY_LOCAL_PROVIDER=openai_compatible
AI_GATEWAY_LOCAL_PROVIDER_BASE_URL=
AI_GATEWAY_LOCAL_PROVIDER_API_KEY=
AI_GATEWAY_LOCAL_CHAT_MODEL=
AI_GATEWAY_LOCAL_EMBEDDING_MODEL=
AI_GATEWAY_LOCAL_EMBEDDING_DIMENSIONS=1024
AI_GATEWAY_LOCAL_RERANK_MODEL=
AI_GATEWAY_LOCAL_RERANK_TOP_N=5
AI_GATEWAY_TIMEOUT=120s
AGENT_MAX_TOKENS=4096
MODEL_ID=
AI_GATEWAY_PROFILE_ID=default-chat
DOCUMENT_AI_GATEWAY_PROFILE_ID=default-chat
DOCUMENT_AI_GATEWAY_MODEL=

MCP_SERVER_TOKEN=<cloud-document-mcp-token>
KNOWLEDGE_MCP_TOKEN=<cloud-knowledge-mcp-token>
