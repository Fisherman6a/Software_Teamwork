# Document service local/default settings.
# Copy to .env for local host runs. Repository Docker Compose only starts infra.

DOCUMENT_HTTP_ADDR=:8085
DOCUMENT_HTTP_PORT=8085

DOCUMENT_POSTGRES_PORT=5432
DOCUMENT_DATABASE_URL=postgres://document_app:document_app_dev@localhost:5432/document_system?sslmode=disable

DOCUMENT_REDIS_PORT=6379
DOCUMENT_REDIS_ADDR=localhost:6379

DOCUMENT_FILE_SERVICE_URL=http://localhost:8082
DOCUMENT_FILE_SERVICE_TOKEN=
DOCUMENT_AI_GATEWAY_URL=http://localhost:8086
DOCUMENT_AI_GATEWAY_PROFILE_ID=default-chat
DOCUMENT_AI_GATEWAY_SERVICE_TOKEN=
DOCUMENT_KNOWLEDGE_SERVICE_URL=
DOCUMENT_KNOWLEDGE_SERVICE_TOKEN=
INTERNAL_SERVICE_TOKEN=local-dev-internal-service-token-change-me

# Streamable HTTP MCP endpoint served by the document process.
DOCUMENT_MCP_PATH=/mcp
DOCUMENT_MCP_SERVICE_TOKEN=local-dev-internal-service-token-change-me
DOCUMENT_MCP_TOKEN_HEADER=Authorization

DOCUMENT_PANDOC_PATH=pandoc
DOCUMENT_LIBREOFFICE_PATH=soffice
DOCUMENT_SHUTDOWN_TIMEOUT=10s
